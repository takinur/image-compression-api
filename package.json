{
  "name": "image-compression-api",
  "version": "1.0.0",
  "description": "Client-side image compression and upload service with Stripe integration",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.client.json",
    "build:server": "tsc",
    "build:client": "tsc -p tsconfig.client.json",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.18",
    "@types/multer": "^1.4.8",
    "@types/node": "^20.8.0",
    "@types/nodemailer": "^6.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
